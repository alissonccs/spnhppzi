function_MOD03_RW2 <- function(N,
alpha1_r,
alpha2_r,
beta1_r,
beta2_r,
pi_r,
fu.max,
fu.min,
sp_tau_r,
spMat,
folder) {
# 1) Gera covari├Īveis
set.seed(5832)
cov.fu <- gencovfu(
N = N,
fu.min = fu.min,
fu.max = fu.max,
cens.prob = 0,
dist.x = c("binomial", "normal"),
par.x = list(0.7, c(0, 1)),
beta.x = c(beta1_r, beta2_r)
)
set.seed(NULL)
# 2) Fun├¦├Żo que cada n├│ do cluster vai rodar
run_montecarlo <- function(step) {
set.seed(258258 * step)
base_sp <- spsimrec(
N = cov.fu$N,
cov_rec = c("ID", "X1", "X2"),
beta_x_rec = c(beta1_r, beta2_r),
logist = 0,
x1 = cov.fu$x1,
fu = cov.fu$fu,
fu_max = cov.fu$fu.max,
fu_min = cov.fu$fu.min,
spatial = 1,
list_area = list_area_RMBH,
sp_model = "ICAR",
SP_N = 133,
nb_mat = Adj_matrix,
sp_tau = sp_tau_r,
random_ef = 1,
pi = pi_r,
par_z = 0,
dist_int_func = "weibull",
par_int_func = c(alpha1_r, alpha2_r),
baseline = "plp"
)
dat2  <- as.data.frame(base_sp)
baseZ <- dat2[!duplicated(dat2$ID), ]
baseP <- dat2[dat2$IndRec == 1, ]
baseP$timeV <- 0
MTP <- joint(
formSurv = inla.surv(time = end, event = status, truncation = begin) ~
X1 + X2 + SP_ID,
dataSurv = baseP,
basRisk  = "rw2", NbasRisk = 200,
id       = "ID",
timeVar  = "timeV", assoc = "",
# formLong = IndRec ~ 1 + (1 | ID),
formLong = IndRec ~ 1 + (1 | ID),
family   = "binomial",
dataLong = baseZ,
run      = FALSE
)
# MTP$.args$formula <- update(
#   MTP$.args$formula,
#   . ~ . - SP_ID_S1 + f(SP_ID_S1, model = "besag", graph = spMat)
# )
MTP$.args$formula <- update(
MTP$.args$formula,
. ~ . - SP_ID_S1 + f(SP_ID_S1, model = "besag", graph = spMat,
hyper = list(prec = list(prior = "loggamma", param = c(0.01, 0.01)))
)
)
# MTP_ <- joint.run(MTP, class = "inla")
MTP_ <- joint.run(MTP, class = "inla",control.fixed = list(mean = 0, prec = 0.25))   # Normal(0,4)
# saveRDS(MTP, file = paste0(folder, "MTP_ZI_step_", step,"_",N,"_",alpha1_r,"_",alpha2_r,".rds"))
# -----------------------------
# Salvar dados para gr├Īficos (pars_graf) em TXT (1 arquivo por step)
# -----------------------------
pars_graf <- as.data.frame(tibble::tibble(
step = step,
# t    = MTP$summary.random$baseline1.hazard$ID,
t = MTP_$summary.random$baseline1.hazard$ID,
# haz  = exp(MTP$summary.random$baseline1.hazard$mean),
haz = exp(MTP_$summary.random$baseline1.hazard$mean),
N    = N,
alpha1 = alpha1_r,
alpha2 = alpha2_r,
model = model,
# geo_level = geo_level,
model_specif = model_specif
))
# Nome do arquivo (um por step) - seguro em paralelo
arq_pars_graf_step <- paste0(
folder, "PARS_GRAF_", model_name,
"_step_", sprintf("%03d", step),
"_", formatC(alpha1_r, format = "f", digits = 1),
"_", alpha2_r, "_", N, ".txt"
)
write.table(
pars_graf,
file      = arq_pars_graf_step,
row.names = FALSE,
col.names = TRUE
)
# write.table(
#   pars_graf,
#   file = arq_pars_graf_step,
#   row.names = FALSE,
#   col.names = TRUE,
#   sep = "\t",        # <<< MUITO IMPORTANTE
#   quote = FALSE      # <<< evita \"Model 03 RW2\"
# )
pars_desc <- as.data.frame(MTP_$summary.fixed) %>%
rows_append(MTP_$summary.hyperpar)|>
tibble::rownames_to_column("pars") |>
dplyr::mutate(
pars = dplyr::case_when(
pars == "alpha[1]"    ~ "alpha1",
pars == "alpha[2]"    ~ "alpha2",
pars == "X1_S1"       ~ "beta1",
pars == "X2_S1"       ~ "beta2",
pars == "Precision for SP_ID_S1"~ "sp_tau",
pars == "Intercept_L1" ~ "pi",
TRUE ~ pars
),
mean1 = dplyr::case_when(
pars == "pi" ~ 1 - exp(mean) / (1 + exp(mean)),
TRUE ~ mean
),
real_pars = dplyr::case_when(
pars == "alpha1" ~ alpha1_r,
pars == "alpha2" ~ alpha2_r,
pars == "beta1"  ~ beta1_r,
pars == "beta2"  ~ beta2_r,
pars == "pi"     ~ pi_r,
pars == "sp_tau" ~ sp_tau_r,
TRUE ~ NA_real_
),
step = step,
model = model,
geo_level = geo_level,
model_specif = model_specif,
sample = paste("Sample=", N),
period = 7,
bias = mean1 - real_pars,
eqm  = bias^2,
rbias = 100 * bias / abs(real_pars)
)
# IMPORTANTE: cada n├│ apenas RETORNA o data.frame
return(pars_desc)
# pars_desc
#
}
## ====== PARTE DO SNOWFALL ======
cpus <- 10
sfInit(parallel = TRUE, cpus = cpus)
# Exporta tudo que a run_montecarlo usa e que n├Żo ├® argumento direto
sfExport("cov.fu", "beta1_r", "beta2_r",
"list_area_RMBH", "Adj_matrix",
"sp_tau_r",
"pi_r",
"alpha1_r", "alpha2_r",
"model",
"geo_level",
"model_specif",
"N",
"spMat",
"folder","model_name")
# Carrega pacotes
sfLibrary(spnhppzi)
sfLibrary(dplyr)
sfLibrary(tibble)
sfLibrary(Formula)
sfLibrary(INLA)
sfLibrary(INLAjoint)
sfLibrary(stats)
sfLibrary(splitstackshape)
# Executa um 'step' por vez
tempo_sf <- system.time({
res_list <- sfLapply(lista, run_montecarlo)
})
sfStop()
# Tudo num ├║nico data.frame
res_all <- dplyr::bind_rows(res_list)
# print(tempo_sf)
list(
resultados = res_all,
tempo_sf   = tempo_sf
)
# Grava o arquivo UMA ├║nica vez
arq_saida <- paste0(
folder, model_name, "_",
formatC(alpha1_r, format = "f", digits = 1), "_",
alpha2_r, "_", N, "_.txt"
)
write.table(
res_all,
file = arq_saida,
row.names = FALSE,
col.names = !file.exists(arq_saida),
append = TRUE
)
invisible(res_all)
}
plot_hazard_rw2_vs_true <- function(N,
alpha1_r,
alpha2_r,
mf,
# a2 = 1.3,
base_dir = "/home/user/Documentos/RW2 vs BP",
subdir_prefix = "MTP",
t_min = 0.10,
t_grid_n = NULL) {
# pacotes
stopifnot(requireNamespace("purrr", quietly = TRUE))
stopifnot(requireNamespace("dplyr", quietly = TRUE))
stopifnot(requireNamespace("tibble", quietly = TRUE))
stopifnot(requireNamespace("ggplot2", quietly = TRUE))
# se n├Żo for informado, usa o pr├│prio N para o grid da curva verdadeira
if (is.null(t_grid_n)) t_grid_n <- N
# montar path: exemplo -> "/home/user/.../MTP_500_12.5"
path <- file.path(base_dir, paste0(subdir_prefix, "_", N, "_", mf))
if (!dir.exists(path)) {
stop("Pasta n├Żo encontrada: ", path)
}
# listar arquivos
arquivos <- list.files(
path = path,
pattern = "^PARS_GRAF_.*_step_\\d+_.*\\.txt$",
full.names = TRUE
)
if (length(arquivos) == 0) {
stop("Nenhum arquivo .rds encontrado em: ", path)
}
# fun├¦├Żo para extrair hazard
