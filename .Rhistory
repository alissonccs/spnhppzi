a2 <- unique(dados_pars_graf$alpha2)[1]
t_grid <- seq(min(dados_pars_graf$t), max(dados_pars_graf$t), length.out = 500)
true_df <- tibble(t = t_grid, haz = Bhaz(t_grid, a1, a2))
