plot_hazard_rw2_vs_true <- function(N,
alpha1_r,
alpha2_r,
mf,
# a2 = 1.3,
base_dir = "/home/user/Documentos/RW2 vs BP/MTP_500_6.3_TESTE_mar_2026/TESTE2",
subdir_prefix = "MTP",
t_min = 0.10,
t_grid_n = NULL) {
# pacotes
stopifnot(requireNamespace("purrr", quietly = TRUE))
stopifnot(requireNamespace("dplyr", quietly = TRUE))
stopifnot(requireNamespace("tibble", quietly = TRUE))
stopifnot(requireNamespace("ggplot2", quietly = TRUE))
# se não for informado, usa o próprio N para o grid da curva verdadeira
if (is.null(t_grid_n)) t_grid_n <- N
# montar path: exemplo -> "/home/user/.../MTP_500_12.5"
path <- file.path(base_dir, paste0(subdir_prefix, "_", N, "_", mf))
# path<-base_dir
if (!dir.exists(path)) {
stop("Pasta não encontrada: ", path)
}
# listar arquivos
arquivos <- list.files(
path = path,
pattern = "^PARS_GRAF_.*_step_\\d+_.*\\.txt$",
full.names = TRUE
)
if (length(arquivos) == 0) {
stop("Nenhum arquivo .rds encontrado em: ", path)
}
