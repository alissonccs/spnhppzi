plot_rbias_boxplot <- function(
input_dir,
output_dir,
model_tag,     # prefixo do arquivo
alpha1,
alpha2,
pi,
N,
pars_keep = c("alpha1","alpha2","beta1","beta2","pi","sp_tau"),
y_limits,
title = "Relative Bias - TWO PART RW2",
width = 8,
height = 5,
dpi = 300
) {
stopifnot(requireNamespace("dplyr", quietly = TRUE))
stopifnot(requireNamespace("ggplot2", quietly = TRUE))
# garantir que pastas existam
if (!dir.exists(input_dir)) stop("input_dir n├Żo existe: ", input_dir)
if (!dir.exists(output_dir)) dir.create(output_dir, recursive = TRUE)
# # montar nome do arquivo (mantendo seu padr├Żo final com "_")
# in_file <- file.path(
#   input_dir,
#   paste0(model_tag, "_", alpha1, "_", alpha2, "_", N, "_.txt")
# )
alpha1_chr <- formatC(alpha1, format = "f", digits = 1)
alpha2_chr <- formatC(alpha2, format = "f", digits = 1)
in_file <- file.path(
input_dir,
paste0(model_tag, "_", alpha1_chr, "_", alpha2_chr, "_", N, "_.txt")
)
if (!file.exists(in_file)) {
stop("Arquivo n├Żo encontrado: ", in_file)
}
dados_graf <- read.table(in_file, header = TRUE) |>
dplyr::filter(.data$pars %in% pars_keep)
p <- ggplot2::ggplot(dados_graf, ggplot2::aes(x = pars, y = rbias)) +
ggplot2::geom_boxplot(fill = "lightblue", alpha = 0.7) +
ggplot2::geom_hline(yintercept = 0, color = "red", linewidth = 1) +
ggplot2::labs(
x = "Parameters",
y = "Relative Bias (%)",
title = paste0(title, " | N=", N, " | alpha1=", alpha1, " | alpha2=", alpha2, "| pi=", pi)
) +
ggplot2::coord_cartesian(ylim = y_limits) +
ggplot2::theme_minimal(base_size = 10)
out_file <- file.path(
output_dir,
paste0("rbias_", model_tag, "_", alpha1, "_", alpha2, "_", N, ".png")
)
ggplot2::ggsave(out_file, plot = p, width = width, height = height, dpi = dpi)
list(plot = p, data = dados_graf, in_file = in_file, out_file = out_file)
}
