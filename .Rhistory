# hazard verdadeira
Bhaz <- function(t, a1, a2) a1 * a2 * t^(a2 - 1)
a1 <- alpha1_r
a2 <- alpha2_r
max_y <- ifelse(a1==0.5,2,ifelse(a1==1,4,8))
t_grid <- seq(min(dados_pars_graf$t), max(dados_pars_graf$t), length.out = t_grid_n)
true_df <- tibble::tibble(
t = t_grid,
haz = Bhaz(t_grid, a1, a2)
)
Bhaz <- function(t, a1, a2) a1*a2*t^(a2-1)
