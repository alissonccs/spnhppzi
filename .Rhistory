t<-NULL
#print(t)
U <- runif(1)
if (dist_int_func == "weibull") {
if(baseline==1){
t <- ((-1)*log(U)*(alpha1_eta[i])^(-1))^(1 / alpha2)
}
#ind<-0
# print(i)
# print(t)
# print(fu[i])
if (t>fu[i]){
t<-fu[i]
# ind<-1
}
}
T1 <- cbind(ID[i],t)
## Definição dos tempos de ocorrência dos eventos subsequentes ====
if (recurr[i]==0 & t<fu[i]){
# print(ID[i])
# print(recurr[i])
j<-0
while (t < fu[i]) {
U <- runif(1)
t1 <- t
if (dist_int_func == "weibull") { # weibull
if(baseline==1){
t_new <- ((-1)*log(U)*(alpha1_eta[i])^(-1) + (t1)^(alpha2))^(1 / alpha2)
}
}
#print(t)
if (j==0 & t_new >= fu[i]) next
t<- t_new
j<-j+1
if (t >= fu[i]) break
T1 <- rbind(T1,c(ID[i],t))
# print(T1)
}
}
T<-as.data.frame(rbind(T,T1))
# print(T)
}
colnames(T)<-c("ID","time")
# print(paste("T: ", dim(T)))
## Consolida tabela contendo os dados de saída ====
tab <-T %>%
group_by(ID)%>%
mutate(#individuo = group_indices(),
ngroup=n(),
rep=row_number(),
expand=case_when((ngroup==rep & !(rep==1&(time==0 | time==fu_max)))~2,TRUE~1),
expand1=expand)%>%
expandRows("expand") %>%
mutate(ngroup1=n(),
IndRec=case_when(ngroup1>2~1, TRUE~0),
rep1=row_number(),
begin=case_when(rep1==1~0,TRUE~lag(time)),
end=case_when(ngroup1==rep1~fu_max, TRUE~time),
status=case_when(end==fu_max~0,TRUE~1)) %>%
ungroup() %>%
# left_join(x1,by="ID") %>%
# left_join(rnd_ef1,by="ID") %>%
# left_join(recurr1,by="ID") %>%
dplyr::select(-c(time,ngroup))
return(tab)
#set.seed(NULL)
}
## TEMPO DE OCORRÊNCIA DOS PRIMIEROS EVENTOS - FUNC INTENSIDADE POLINOMIAL ====
#' @title get_nhpp_realization_0
#' @aliases get_nhpp_realization_0
#' @export
#' @description           Gera os tempos de ocorrência dos primeiros eventos.
#' @param lambda          Funćão de intensidade polinomial.
get_nhpp_realization_0 <- function(lambda,fu_max, x, beta_x_rec,rnd_ef){
t_max <- fu_max
t <- 0
s <- 0
Lambda <- function(tupper) integrate(f = lambda,x=x,beta_x_rec=beta_x_rec, rnd_ef, lower = 0, upper = tupper)$value
Lambda_inv <- function(s){
v <- seq(0,t_max+3, length.out = 250)
min(v[Vectorize(Lambda)(v)>=s])
}
X <- numeric(0)
# while(t <= t_max){
u <- runif(1)
s <- s -log(u)
t <- Lambda_inv(s)
X <- c( X, t)
# }
return(X)
}
# 2) Função que cada nó do cluster vai rodar
run_montecarlo <- function(step) {
set.seed(258258 * step)
base_sp <- spsimrec_t(
N = cov.fu$N,
cov_rec = c("ID", "X1", "X2"),
beta_x_rec = c(beta1_r, beta2_r),
logist = 0,
x1 = cov.fu$x1,
fu = cov.fu$fu,
fu_max = cov.fu$fu.max,
fu_min = cov.fu$fu.min,
spatial = 1,
list_area = list_area_RMBH,
sp_model = "ICAR",
SP_N = 133,
nb_mat = Adj_matrix,
sp_tau = sp_tau_r,
random_ef = 1,
pi = pi_r,
par_z = 0,
dist_int_func = "weibull",
par_int_func = c(alpha1_r, alpha2_r),
baseline = "plp"
)
dat2 <- as.data.frame(base_sp) %>%
mutate(IndRec1 = case_when(
recurr == 1 ~ 0,
TRUE ~ 1
))
baseZ <- dat2[!duplicated(dat2$ID), ]
baseP <- dat2[dat2$IndRec1 == 1, ]
# baseP[baseP$status==1, "status"][which(!duplicated(baseP[baseP$status==1, "ID"]))] <- 0
baseP$timeV <- 0
MTP <- joint(
formSurv = inla.surv(time = end, event = status, truncation = begin) ~
X1 + X2 + SP_ID,
dataSurv = baseP,
basRisk  = "rw2", NbasRisk = 1000,
id       = "ID",
timeVar  = "timeV", assoc = "",
# formLong = IndRec ~ 1 + (1 | ID),
formLong = IndRec1 ~ 1 + (1 | ID),
family   = "binomial",
dataLong = baseZ,
run      = FALSE
)
# MTP$.args$formula <- update(
#   MTP$.args$formula,
#   . ~ . - SP_ID_S1 + f(SP_ID_S1, model = "besag", graph = spMat)
# )
MTP$.args$formula <- update(
MTP$.args$formula,
. ~ . - SP_ID_S1 + f(SP_ID_S1, model = "besag", graph = spMat,
hyper = list(prec = list(prior = "loggamma", param = c(0.01, 0.01)))
)
)
# MTP_ <- joint.run(MTP, class = "inla")
MTP_ <- joint.run(MTP, class = "inla",control.fixed = list(mean = 0, prec = 0.25))   # Normal(0,4)
# saveRDS(MTP, file = paste0(folder, "MTP_ZI_step_", step,"_",N,"_",alpha1_r,"_",alpha2_r,".rds"))
# -----------------------------
# Salvar dados para gráficos (pars_graf) em TXT (1 arquivo por step)
# -----------------------------
pars_graf <- as.data.frame(tibble::tibble(
step = step,
# t    = MTP$summary.random$baseline1.hazard$ID,
t = MTP_$summary.random$baseline1.hazard$ID,
# haz  = exp(MTP$summary.random$baseline1.hazard$mean),
haz = exp(MTP_$summary.random$baseline1.hazard$mean),
N    = N,
alpha1 = alpha1_r,
alpha2 = alpha2_r,
model = model,
# geo_level = geo_level,
model_specif = model_specif
))
# Nome do arquivo (um por step) - seguro em paralelo
arq_pars_graf_step <- paste0(
folder, "PARS_GRAF_", model_name,
"_step_", sprintf("%03d", step),
"_", formatC(alpha1_r, format = "f", digits = 1),
"_", alpha2_r, "_", N, ".txt"
)
write.table(
pars_graf,
file      = arq_pars_graf_step,
row.names = FALSE,
col.names = TRUE
)
# write.table(
#   pars_graf,
#   file = arq_pars_graf_step,
#   row.names = FALSE,
#   col.names = TRUE,
#   sep = "\t",        # <<< MUITO IMPORTANTE
#   quote = FALSE      # <<< evita \"Model 03 RW2\"
# )
pars_desc <- as.data.frame(MTP_$summary.fixed) %>%
rows_append(MTP_$summary.hyperpar)|>
tibble::rownames_to_column("pars") |>
dplyr::mutate(
pars = dplyr::case_when(
pars == "alpha[1]"    ~ "alpha1",
pars == "alpha[2]"    ~ "alpha2",
pars == "X1_S1"       ~ "beta1",
pars == "X2_S1"       ~ "beta2",
pars == "Precision for SP_ID_S1"~ "sp_tau",
pars == "Intercept_L1" ~ "pi",
TRUE ~ pars
),
mean1 = dplyr::case_when(
pars == "pi" ~ 1 - exp(mean) / (1 + exp(mean)),
TRUE ~ mean
),
real_pars = dplyr::case_when(
pars == "alpha1" ~ alpha1_r,
pars == "alpha2" ~ alpha2_r,
pars == "beta1"  ~ beta1_r,
pars == "beta2"  ~ beta2_r,
pars == "pi"     ~ pi_r,
pars == "sp_tau" ~ sp_tau_r,
TRUE ~ NA_real_
),
step = step,
model = model,
geo_level = geo_level,
model_specif = model_specif,
sample = paste("Sample=", N),
period = 7,
bias = mean1 - real_pars,
eqm  = bias^2,
rbias = 100 * bias / abs(real_pars)
)
# IMPORTANTE: cada nó apenas RETORNA o data.frame
return(pars_desc)
# pars_desc
#
}
## ====== PARTE DO SNOWFALL ======
cpus <- 10
sfInit(parallel = TRUE, cpus = cpus)
# Exporta tudo que a run_montecarlo usa e que não é argumento direto
sfExport("cov.fu", "beta1_r", "beta2_r",
"list_area_RMBH", "Adj_matrix",
"sp_tau_r",
"pi_r",
"alpha1_r", "alpha2_r",
"model",
"geo_level",
"model_specif",
"N",
"spMat",
"folder","model_name")
# Carrega pacotes
sfLibrary(spnhppzi)
sfLibrary(dplyr)
sfLibrary(tibble)
sfLibrary(Formula)
sfLibrary(INLA)
sfLibrary(INLAjoint)
sfLibrary(stats)
sfLibrary(splitstackshape)
# Executa um 'step' por vez
tempo_sf <- system.time({
res_list <- sfLapply(lista, run_montecarlo)
})
sfStop()
# Tudo num único data.frame
res_all <- dplyr::bind_rows(res_list)
# print(tempo_sf)
list(
resultados = res_all,
tempo_sf   = tempo_sf
)
# Grava o arquivo UMA única vez
arq_saida <- paste0(
folder, model_name, "_",
formatC(alpha1_r, format = "f", digits = 1), "_",
alpha2_r, "_", N, "_.txt"
)
write.table(
res_all,
file = arq_saida,
row.names = FALSE,
col.names = !file.exists(arq_saida),
append = TRUE
)
invisible(res_all)
}
